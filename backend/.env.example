# Agent identity — create an account on Tangled and fill these in
# Use an app password (Settings > App Passwords), never your main password
AGENT_HANDLE=your-agent.tangled.sh
AGENT_PASSWORD=your-app-password
AGENT_PDS=https://tngl.sh
VITE_API_BASE=http://localhost:8000

# Serve the committed local JSON pools at runtime instead of warming reads from
# the agent PDS. 1 = local pools are the read source; the agent PDS stays a
# write-only community store (the firehose ingester still upserts into it). Use
# when the PDS is only partially synced but the local pools are current.
# 0 / unset = warm reads from the agent PDS (the default).
SERVE_LOCAL_POOLS=0

# Live firehose ingestion (opt-in). 1 = subscribe at the live tip and continuously
# fold newly-active Tangled DIDs (their repos/issues) into the pool, so the feed
# reflects the newest activity without a restart. 0 / unset = off (snapshot only).
LIVE_INGEST=0
# Min seconds before re-ingesting the same DID (collapses event bursts). New DIDs
# are always ingested immediately; smaller = a known user's new content lands sooner.
LIVE_INGEST_DEBOUNCE_S=30